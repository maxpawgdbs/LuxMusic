# Core
SECRET_KEY=change-this-in-production-very-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Storage and DB
SQLITE_PATH=luxmusic.db
MUSIC_DIR=music

# CORS for web/mobile clients
# Example: CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:5173"]
CORS_ORIGINS=["*"]

# Optional bootstrap admin account (created on app startup)
BOOTSTRAP_ADMIN_EMAIL=admin@luxmusic.local
BOOTSTRAP_ADMIN_PASSWORD=AdminPass123!
